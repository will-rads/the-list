# The List — environment variables
# Copy to `.env` and fill in. `.env` is gitignored. Never commit secrets.

# ─── Gemini (transcripts, copy generation) ─────────────────────────
GEMINI_API_KEY=AIza_replace_me

# ─── Supabase (planned: auth + db + storage) ───────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ_replace_me
SUPABASE_SERVICE_ROLE_KEY=eyJ_replace_me_keep_secret

# ─── GitHub (only if running automation against the repo) ──────────
GITHUB_TOKEN=ghp_replace_me

# ─── Phyllo (creator data — replaces direct IG scraping) ───────────
# Phyllo Identity API: lookup by handle, returns followers + audience demo
# Phyllo Connect SDK: OAuth flow for verified upgrade (Tier 1 → Verified)
# Sign up: https://www.getphyllo.com → grab from dashboard → Developers
PHYLLO_CLIENT_ID=
PHYLLO_CLIENT_SECRET=
PHYLLO_ENV=sandbox            # sandbox | staging | production

# ─── Instagram Graph API (only if we skip Phyllo's Connect SDK later) ─
# We rely on Phyllo for IG OAuth in v1. Keep these empty unless we switch.
IG_APP_ID=
IG_APP_SECRET=
IG_ACCESS_TOKEN=

# ─── APNs / push (planned: notifications) ──────────────────────────
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=com.thelist.app
# Path to the .p8 key file (kept OUTSIDE the repo, gitignored)
APNS_KEY_PATH=/path/outside/repo/AuthKey_XXXXXXXXXX.p8
