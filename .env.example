# The List — environment variables
# Copy to `.env` and fill in. `.env` is gitignored. Never commit secrets.

# ─── Gemini (transcripts, copy generation) ─────────────────────────
GEMINI_API_KEY=AIza_replace_me

# ─── Supabase (planned: auth + db + storage) ───────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ_replace_me
SUPABASE_SERVICE_ROLE_KEY=eyJ_replace_me_keep_secret

# ─── GitHub (only if running automation against the repo) ──────────
GITHUB_TOKEN=ghp_replace_me

# ─── Creator data provider (handle → audience demographics) ────────
# Backend abstracts whichever vendor we pick behind a single interface.
# CREATOR_DATA_PROVIDER = phyllo | modash | ensembledata | hypeauditor
CREATOR_DATA_PROVIDER=
CREATOR_DATA_API_KEY=

# Vendor-specific keys (uncomment the block we actually choose) ─────
# # Phyllo  https://www.getphyllo.com
# PHYLLO_CLIENT_ID=
# PHYLLO_CLIENT_SECRET=
# PHYLLO_ENV=sandbox
#
# # Modash  https://www.modash.io
# MODASH_API_KEY=
#
# # Ensembledata  https://ensembledata.com
# ENSEMBLEDATA_API_KEY=

# ─── Instagram Graph API (only if we go direct — fallback path) ────
# Most providers above handle this for us. Keep empty unless we DIY.
IG_APP_ID=
IG_APP_SECRET=
IG_ACCESS_TOKEN=

# ─── APNs / push (planned: notifications) ──────────────────────────
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=com.thelist.app
# Path to the .p8 key file (kept OUTSIDE the repo, gitignored)
APNS_KEY_PATH=/path/outside/repo/AuthKey_XXXXXXXXXX.p8
